; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Goblin Mayhem TD"
run/main_scene="uid://glkqem0qes2a"
config/features=PackedStringArray("4.5", "C#", "Mobile")

[autoload]

GameSettings="*res://scripts/ui/autoload/GameSettings.cs"
SaveSystem="*res://scripts/ui/autoload/SaveSystem.cs"
Base="*res://scripts/ui/autoload/Base.cs"
Wave="*res://scripts/ui/autoload/Wave.cs"
Recursos="*res://scripts/ui/autoload/Recursos.cs"
BuildTime="*res://scripts/ui/autoload/BuildTime.cs"

[dotnet]

project/assembly_name="Goblin Mayhem TD"

[editor_plugins]

enabled=PackedStringArray("res://addons/GDScript/addons/YATI/plugin.cfg")

[file_customization]

